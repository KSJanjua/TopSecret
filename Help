grep -n "mask\|objects\|ground\|all\|restrict\|region" evaluate.py | head -30

export DINOV2_WEIGHTS=/home/work/intern_storage/Ayush/weights/dinov2_vitl14.safetensors
export HF_HUB_OFFLINE=1

# +H : holistic only, inside person masks
python evaluate.py --model-config instancedepth/configs/instance_depth.yaml \
    --data-root gid_custom --checkpoint runs/phase1/ckpt_final.pth \
    --split test --image-size 504 896 --use-init-depth --mask objects \
    --out-json eval_phase1_obj.json

# +H+I : instance head
python evaluate.py --model-config instancedepth/configs/instance_depth.yaml \
    --data-root gid_custom --checkpoint runs/phase2/ckpt_final.pth \
    --split test --image-size 504 896 --mask objects --out-json eval_phase2_obj.json

# +H+I+R : full refined model
python evaluate.py --model-config instancedepth/configs/instance_depth.yaml \
    --data-root gid_custom --checkpoint runs/phase3/ckpt_final.pth \
    --split test --image-size 504 896 --mask objects --out-json eval_phase3_obj.json

for f in eval_phase1_obj eval_phase2_obj eval_phase3_obj; do echo "== $f =="; cat $f.json; echo; done
