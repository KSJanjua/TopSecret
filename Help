cd /home/work/intern_storage/Ayush/InstanceDepthRepo
python - <<'PY'
import torch, yaml
from instancedepth.build import build_instance_depth
from instancedepth.utils.checkpoint import load_checkpoint
from instancedepth.losses.refine_losses import RefinementCriterion
from instancedepth.models.instance.matcher import HungarianMatcher
from instancedepth.data.gid_dataset import GIDInstanceDepthDataset, GIDDatasetConfig, collate_gid, build_refine_targets
from torch.utils.data import DataLoader

cfg=yaml.safe_load(open("instancedepth/configs/instance_depth.yaml")); cfg.setdefault("backbone",{})["pretrained"]=False
m=build_instance_depth(cfg).cuda(); load_checkpoint("runs/phase2/ckpt_final.pth",m); m.set_phase(3); m.eval()
crit=RefinementCriterion().cuda(); match=HungarianMatcher()
ds=GIDInstanceDepthDataset(GIDDatasetConfig(annotations_root="gid_custom",split="train",image_size=(504,896)))
dl=DataLoader(ds,batch_size=2,shuffle=True,num_workers=2,collate_fn=collate_gid,drop_last=True)
shown=0
with torch.no_grad():
    for i,b in enumerate(dl):
        out=m(b["image"].cuda(),run_instance=True,run_refine=True)
        meta=out.get("refine_meta")
        if meta is None or meta["pair_query_idx"].numel()==0: continue
        tg=[{k:(v.cuda() if torch.is_tensor(v) else v) for k,v in t.items()} for t in b["targets"]]
        dt,valid=build_refine_targets(meta["pair_query_idx"],meta["batch_index"],match(out,tg),tg)
        if valid.sum()==0: continue
        lr=crit(out["d_hat"][valid],dt[valid])
        print(f"batch {i}: pairs={meta['pair_query_idx'].numel()}  obj={float(lr['loss_obj']):.4f}  dist={float(lr['loss_dist']):.4f}")
        shown+=1
        if shown>=5: break
    if shown==0: print("no pair-bearing batches in sample (just sparse — rerun or increase range)")
PY
