cd /home/work/intern_storage/Ayush/InstanceDepthRepo
python - <<'PY'
import torch, yaml
from instancedepth.build import build_instance_depth
from instancedepth.utils.checkpoint import load_checkpoint
from instancedepth.data.gid_dataset import GIDInstanceDepthDataset, GIDDatasetConfig, collate_gid
from torch.utils.data import DataLoader

cfg=yaml.safe_load(open("instancedepth/configs/instance_depth.yaml")); cfg.setdefault("backbone",{})["pretrained"]=False
m=build_instance_depth(cfg).cuda(); load_checkpoint("runs/phase2/ckpt_final.pth",m); m.set_phase(3); m.eval()
ds=GIDInstanceDepthDataset(GIDDatasetConfig(annotations_root="gid_custom",split="train",image_size=(504,896)))
dl=DataLoader(ds,batch_size=2,shuffle=True,num_workers=2,collate_fn=collate_gid,drop_last=True)

pairs_total=0; frames_with_pairs=0; conf_max=[]
with torch.no_grad():
    for i,b in enumerate(dl):
        out=m(b["image"].cuda(),run_instance=True,run_refine=True)
        # peek at instance confidences (softmax over classes, person prob)
        probs=out["pred_logits"].softmax(-1)[...,:-1].max(-1).values   # (B,N) best non-bg prob
        conf_max.append(float(probs.max()))
        meta=out.get("refine_meta")
        npair = int(meta["pair_query_idx"].numel()) if (meta is not None and meta.get("pair_query_idx") is not None) else 0
        pairs_total+=npair
        frames_with_pairs+= (npair>0)
        if i>=60: break
print(f"batches checked: {i+1}")
print(f"batches that produced >=1 pair: {frames_with_pairs}")
print(f"total pairs found: {pairs_total}")
print(f"max person-confidence seen across batches: {max(conf_max):.3f}")
print(f"  (pair filter needs class>0.9 AND mask>0.8 AND IoU>0.1)")
PY
