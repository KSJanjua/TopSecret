optim.zero_grad(set_to_none=True)
        loss.backward()
        grad_norm = torch.nn.utils.clip_grad_norm_(params, args.clip_grad)
        if torch.isfinite(grad_norm):
            optim.step()
        else:
            log.warning("step %d: non-finite grad norm (%.3e) -- update skipped",
                        step, float(grad_norm))
