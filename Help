import timm  # local import: package imports cleanly even without timm
        import os

        _overlay = None
        _w = os.environ.get("DINOV2_WEIGHTS")     # local DINOv2 weights for offline clusters
        if _w:
            _overlay = dict(file=_w)

        self.vit = timm.create_model(
            cfg.model_name,
            pretrained=cfg.pretrained,
            num_classes=0,
            dynamic_img_size=True,
            pretrained_cfg_overlay=_overlay,       # None by default -> normal behavior
        )

