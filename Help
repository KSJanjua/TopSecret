cd /home/work/intern_storage/Ayush/InstanceDepthRepo
python - <<'PY'
import torch, yaml, torch.nn.functional as F
from instancedepth.build import build_instance_depth
from instancedepth.utils.checkpoint import load_checkpoint
from instancedepth.losses import instance_losses as IL
from instancedepth.data.gid_dataset import GIDInstanceDepthDataset, GIDDatasetConfig, collate_gid
from instancedepth.models.instance.matcher import HungarianMatcher
from torch.utils.data import DataLoader

cfg = yaml.safe_load(open("instancedepth/configs/instance_depth.yaml"))
cfg.setdefault("backbone",{})["pretrained"]=False
m = build_instance_depth(cfg).cuda(); load_checkpoint("runs/phase1/ckpt_final.pth", m); m.set_phase(2); m.train()

crit = IL.InstanceSetCriterion(num_classes=cfg.get("instance",{}).get("num_classes",1)).cuda()
match = HungarianMatcher()
ds = GIDInstanceDepthDataset(GIDDatasetConfig(annotations_root="gid_custom",split="train",image_size=(504,896)))
dl = DataLoader(ds,batch_size=4,shuffle=True,num_workers=2,collate_fn=collate_gid,drop_last=True)

for i,b in enumerate(dl):
    rgb=b["image"].cuda()
    tg=[{k:(v.cuda() if torch.is_tensor(v) else v) for k,v in t.items()} for t in b["targets"]]
    out=m(rgb,run_instance=True,run_refine=False)
    # how many GT instances per image this batch?
    ng=[int(t["labels"].numel()) for t in tg]
    idx=match(out,tg)
    li=crit(out,tg,idx)
    bad=[k for k,v in li.items() if torch.is_tensor(v) and not torch.isfinite(v).all()]
    print(f"step {i:3d} gt_per_img={ng}  nan_terms={bad if bad else 'none'}  "
          + " ".join(f"{k}={float(v):.3f}" for k,v in li.items() if torch.is_tensor(v) and torch.isfinite(v).all()))
    if bad: print(">>> NaN appears at step",i,"in",bad); break
    if i>=120: print("120 steps clean"); break
PY
