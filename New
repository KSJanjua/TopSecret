import json, os, numpy as np
root = "gid_custom"
ids = []
for s in ("train", "test"):
    p = os.path.join(root, f"{s}.txt")
    if os.path.exists(p):
        ids += [x.strip() for x in open(p) if x.strip()]

rows = []                       # one entry per frame that has >=1 zero-depth instance
frames_total = 0
frames_with_zero = 0
inst_total = 0
inst_zero = 0

for sid in ids:
    man = json.load(open(os.path.join(root, sid, "annotations.json")))
    for fkey, fr in man["frames"].items():
        frames_total += 1
        n_inst = len(fr["instances"])
        inst_total += n_inst
        bad_tracks = []
        for inst in fr["instances"]:
            d = float(inst.get("depth_layer_m", 0.0))
            if not (np.isfinite(d) and d > 0):
                bad_tracks.append(inst.get("track_id"))
                inst_zero += 1
        if bad_tracks:
            frames_with_zero += 1
            rows.append((sid, fkey, len(bad_tracks), n_inst, bad_tracks))

# ---- summary ----
print(f"frames total                       : {frames_total}")
print(f"frames with >=1 zero-depth instance: {frames_with_zero}  "
      f"({100*frames_with_zero/max(frames_total,1):.1f}%)")
print(f"instances total                    : {inst_total}")
print(f"instances with zero depth          : {inst_zero}  "
      f"({100*inst_zero/max(inst_total,1):.1f}%)")
print(f"frames where ALL instances are zero : "
      f"{sum(1 for r in rows if r[2]==r[3])}")
print()

# ---- first 40 affected frames (sequence | frame | zero/total | track ids) ----
print("examples (sequence | frame | zero/total instances | zero track_ids):")
for sid, fkey, nz, nt, tracks in rows[:40]:
    print(f"  {sid} | {fkey} | {nz}/{nt} | tracks={tracks}")
if len(rows) > 40:
    print(f"  ... and {len(rows)-40} more affected frames")

# ---- save the full list to a file so you can inspect/share it ----
with open("zero_depth_frames.txt", "w") as f:
    f.write("sequence\tframe\tzero_instances\ttotal_instances\tzero_track_ids\n")
    for sid, fkey, nz, nt, tracks in rows:
        f.write(f"{sid}\t{fkey}\t{nz}\t{nt}\t{','.join(map(str,tracks))}\n")
print(f"\nfull list ({len(rows)} frames) written to: zero_depth_frames.txt")
