import torch, yaml
from instancedepth.build import build_instance_depth
from instancedepth.utils.checkpoint import load_checkpoint
from instancedepth.losses.refine_losses import RefinementCriterion
from instancedepth.models.instance.matcher import HungarianMatcher
from instancedepth.data.gid_dataset import (
    GIDInstanceDepthDataset, GIDDatasetConfig, collate_gid, build_refine_targets)
from torch.utils.data import DataLoader

cfg = yaml.safe_load(open("instancedepth/configs/instance_depth.yaml"))
cfg.setdefault("backbone", {})["pretrained"] = False
m = build_instance_depth(cfg).cuda()
load_checkpoint("runs/phase3/ckpt_final.pth", m)      # your final model
m.set_phase(3); m.eval()
crit = RefinementCriterion().cuda(); match = HungarianMatcher()

ds = GIDInstanceDepthDataset(GIDDatasetConfig(
    annotations_root="gid_custom", split="test",
    image_size=(504, 896), hflip_prob=0.0))
dl = DataLoader(ds, batch_size=2, shuffle=False, num_workers=4, collate_fn=collate_gid)

N_BATCHES = 300                      # sample; raise for the whole set
batches = with_pairs = total_pairs = 0
objs, dists = [], []
with torch.no_grad():
    for i, b in enumerate(dl):
        if i >= N_BATCHES: break
        batches += 1
        out = m(b["image"].cuda(), run_instance=True, run_refine=True)
        meta = out.get("refine_meta")
        npair = int(meta["pair_query_idx"].numel()) if (meta and meta.get("pair_query_idx") is not None) else 0
        if npair == 0:
            continue
        with_pairs += 1; total_pairs += npair
        tg = [{k: (v.cuda() if torch.is_tensor(v) else v) for k, v in t.items()} for t in b["targets"]]
        dt, valid = build_refine_targets(meta["pair_query_idx"], meta["batch_index"], match(out, tg), tg)
        if valid.sum() == 0:
            continue
        lr = crit(out["d_hat"][valid], dt[valid])
        objs.append(float(lr["loss_obj"])); dists.append(float(lr["loss_dist"]))

import numpy as np
print(f"batches checked                    : {batches}")
print(f"batches WITH an occluding pair     : {with_pairs}  ({100*with_pairs/max(batches,1):.1f}%)")
print(f"batches with NO pair (no refine)   : {batches-with_pairs}  ({100*(batches-with_pairs)/max(batches,1):.1f}%)")
print(f"total occluding pairs found        : {total_pairs}")
if objs:
    print(f"refinement loss on pair-frames     : obj~{np.mean(objs):.4f}  dist~{np.mean(dists):.4f}")
print()
print("-> occlusion refinement only acts on the small % of frames with")
print("   overlapping people; that is why whole-image depth metrics barely move.")
